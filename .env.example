# ─── Application ──────────────────────────────────────────────
# "production" | "development"  — Skips loading .env in production
NODE_ENV=development

# ─── Telegram ─────────────────────────────────────────────────
# Token provided by BotFather when you create the bot
TELEGRAM_BOT_TOKEN=your_bot_token_here 

# "polling" → bot pulls updates (ideal for local dev, no public URL needed)
# "webhook" → Telegram pushes updates to your server (required for production)
BOT_MODE=polling

# Only required when BOT_MODE=webhook
# Your server's public HTTPS URL (no trailing slash)
WEBHOOK_URL=https://your-public-domain.com

# URL path where Telegram will POST updates (can be left as default)
WEBHOOK_PATH=/telegram/webhook

# Random secret string (min 16 chars) shared between Telegram and your server.
# Telegram sends it in the X-Telegram-Bot-Api-Secret-Token header so your
# server can reject requests that did not come from Telegram.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WEBHOOK_SECRET=replace_with_a_long_random_string

# ─── Server ───────────────────────────────────────────────────
# TCP port the Express server listens on
PORT=3000

# ─── PostgreSQL ───────────────────────────────────────────────
# Full connection string — format: postgres://user:password@host:port/database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/telegram_bot

# Set to "true" when the DB host requires SSL (e.g. Render, Railway, Supabase)
DATABASE_SSL=false

# Maximum number of simultaneous DB connections in the pool (default: 10)
DB_POOL_MAX=10

# ─── Matching engine ──────────────────────────────────────────
# Supported currencies shown as buttons in the buy/sell wizard.
# Comma-separated, for example: USD,EUR,USDT,MLC
SUPPORTED_CURRENCIES=USD,EUR,USDT

# How many % above/below the target price is still considered a "near" match.
# Example: buyer targets 100, a seller at 108 is within 10% → near match.
NEAR_MATCH_PERCENT=10

# ─── UX feedback ──────────────────────────────────────────────
# Interval (ms) to refresh Telegram "typing..." while processing a request.
LOADER_INTERVAL_MS=4000

# After process start, users get a one-time warm-up message during this window.
# Useful when the service is waking up from idle/cold start on platforms like Render.
COLD_START_HINT_WINDOW_SECONDS=180

